<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_tour_booking_group_tree_tbm" model="ir.ui.view">
        <field name="name">tour.booking.group.tree.tbm</field>
        <field name="model">tour.booking.group</field>
        <field name="arch" type="xml">
            <list string="Booking Groups" create="0" edit="0" delete="0">
                <field name="name"/>
                <field name="package_id"/>
                <field name="travel_start_date"/>
                <field name="travel_end_date"/>
                <field name="booking_count"/>
                <field name="customer_count"/>
                <field name="total_persons"/>
                <field name="total_amount" widget="monetary"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_tour_booking_group_form_tbm" model="ir.ui.view">
        <field name="name">tour.booking.group.form.tbm</field>
        <field name="model">tour.booking.group</field>
        <field name="arch" type="xml">
            <form string="Booking Group">
                <header>
                    <button name="action_refresh_group" type="object" string="Refresh Group" class="oe_highlight"/>
                    <button name="action_view_bookings" type="object" string="Open Bookings" class="btn-secondary"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="package_id" readonly="1"/>
                            <field name="travel_start_date" readonly="1"/>
                        </group>
                        <group>
                            <field name="travel_end_date" readonly="1"/>
                            <field name="booking_count" readonly="1"/>
                            <field name="customer_count" readonly="1"/>
                            <field name="total_persons" readonly="1"/>
                            <field name="total_amount" widget="monetary" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Bookings">
                            <field name="line_ids" nolabel="1" readonly="1">
                                <list string="Bookings" create="0" edit="0" delete="0">
                                    <field name="booking_id"/>
                                    <field name="partner_id"/>
                                    <field name="state"/>
                                    <field name="travel_end_date"/>
                                    <field name="total_persons"/>
                                    <field name="price_total" widget="monetary"/>
                                    <field name="currency_id" column_invisible="1"/>
                                    <field name="note"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tour_booking_group_search_tbm" model="ir.ui.view">
        <field name="name">tour.booking.group.search.tbm</field>
        <field name="model">tour.booking.group</field>
        <field name="arch" type="xml">
            <search string="Search Booking Groups">
                <field name="name"/>
                <field name="package_id"/>
                <field name="travel_start_date"/>
                <group expand="0" string="Group By">
                    <filter string="Package" name="group_by_package" context="{'group_by': 'package_id'}"/>
                    <filter string="Start Date" name="group_by_start_date" context="{'group_by': 'travel_start_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_tour_booking_tbm" model="ir.actions.act_window">
        <field name="name">Booking Groups</field>
        <field name="res_model">tour.booking.group</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_tour_booking_group_search_tbm"/>
    </record>

</odoo>
