<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Tour Package Tree View -->
    <record id="tour_package_view_tree" model="ir.ui.view">
        <field name="name">tour.package.view.tree</field>
        <field name="model">tour.package</field>
        <field name="arch" type="xml">
            <list string="Tour Packages" sample="1">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="destination"/>
                <field name="category_id"/>
                <field name="duration_days"/>
                <field name="base_price" widget="monetary"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="state" decoration-success="state=='published'" decoration-info="state=='draft'" decoration-muted="state=='archived'"/>
                <field name="is_published" widget="boolean_toggle"/>
                <field name="booking_count"/>
                <field name="inquiry_count"/>
                <field name="view_count"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>
    
    <!-- Tour Package Form View -->
    <record id="tour_package_view_form" model="ir.ui.view">
        <field name="name">tour.package.view.form</field>
        <field name="model">tour.package</field>
        <field name="arch" type="xml">
            <form string="Tour Package">
                <header>
                    <button name="action_publish" type="object" string="Publish" class="oe_highlight" invisible="state == 'published'"/>
                    <button name="action_draft" type="object" string="Set to Draft" invisible="state == 'draft'"/>
                    <button name="action_archive" type="object" string="Archive" invisible="state == 'archived'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,published"/>
                </header>
                <sheet>
                    <field name="image_1920" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <label for="name" string="Package Name"/>
                        <h1>
                            <field name="name" placeholder="e.g. 7 Days Paris Tour"/>
                        </h1>
                        <div class="o_row">
                            <field name="code" readonly="1"/>
                            <field name="is_featured" widget="boolean_toggle"/>
                            <label for="is_featured"/>
                            <field name="is_popular" widget="boolean_toggle"/>
                            <label for="is_popular"/>
                        </div>
                    </div>
                    <group>
                        <group>
                            <field name="category_id"/>
                            <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                            <field name="destination"/>
                            <field name="country_id"/>
                            <field name="user_id"/>
                        </group>
                        <group>
                            <field name="duration_days"/>
                            <field name="duration_nights"/>
                            <field name="sequence"/>
                            <field name="active" invisible="1"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="short_description" placeholder="Short description for list view..."/>
                            <field name="description" widget="html" placeholder="Detailed package description..."/>
                        </page>
                        <page string="Pricing" name="pricing">
                            <group>
                                <group>
                                    <field name="price_type"/>
                                    <field name="currency_id"/>
                                    <field name="base_price" widget="monetary"/>
                                </group>
                                <group invisible="price_type != 'per_person'">
                                    <field name="adult_price" widget="monetary"/>
                                    <field name="child_price" widget="monetary"/>
                                    <field name="infant_price" widget="monetary"/>
                                </group>
                            </group>
                        </page>
                        <page string="Itinerary" name="itinerary">
                            <field name="itinerary_ids" context="{'default_package_id': id}">
                                <list editable="bottom">
                                    <field name="day_number"/>
                                    <field name="name"/>
                                    <field name="location"/>
                                    <field name="start_time" widget="float_time"/>
                                    <field name="end_time" widget="float_time"/>
                                    <field name="hotel_id"/>
                                    <field name="transportation_id"/>
                                </list>
                            </field>
                        </page>
                        <page string="Inclusions &amp; Exclusions" name="inclusions">
                            <group>
                                <group string="Inclusions">
                                    <field name="inclusion_ids" nolabel="1" context="{'default_package_id': id}">
                                        <list editable="bottom">
                                            <field name="sequence" widget="handle"/>
                                            <field name="name"/>
                                            <field name="icon"/>
                                        </list>
                                    </field>
                                </group>
                                <group string="Exclusions">
                                    <field name="exclusion_ids" nolabel="1" context="{'default_package_id': id}">
                                        <list editable="bottom">
                                            <field name="sequence" widget="handle"/>
                                            <field name="name"/>
                                            <field name="icon"/>
                                        </list>
                                    </field>
                                </group>
                            </group>
                        </page>
                        <page string="Services" name="services">
                            <group>
                                <group string="Hotels">
                                    <field name="hotel_ids" widget="many2many_tags" nolabel="1"/>
                                </group>
                                <group string="Transportation">
                                    <field name="transportation_ids" widget="many2many_tags" nolabel="1"/>
                                </group>
                            </group>
                            <group>
                                <group string="Meals">
                                    <field name="meal_ids" widget="many2many_tags" nolabel="1"/>
                                </group>
                                <group string="Attractions">
                                    <field name="attraction_ids" widget="many2many_tags" nolabel="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Availability" name="availability">
                            <group>
                                <group>
                                    <field name="available_from"/>
                                    <field name="available_to"/>
                                </group>
                                <group>
                                    <field name="min_persons"/>
                                    <field name="max_persons"/>
                                </group>
                            </group>
                        </page>
                        <page string="Images" name="images">
                            <field name="image_ids" context="{'default_package_id': id}">
                                <kanban>
                                    <field name="id"/>
                                    <field name="name"/>
                                    <field name="image_1920"/>
                                    <templates>
                                        <t t-name="kanban-box">
                                            <div class="oe_kanban_global_click">
                                                <div class="o_kanban_image">
                                                    <img t-att-src="kanban_image('tour.package.image', 'image_1920', record.id.raw_value)" alt="Package Image"/>
                                                </div>
                                                <div class="oe_kanban_details">
                                                    <strong><field name="name"/></strong>
                                                </div>
                                            </div>
                                        </t>
                                    </templates>
                                </kanban>
                            </field>
                        </page>
                        <page string="Terms &amp; Conditions" name="terms">
                            <group>
                                <field name="terms_conditions" widget="html" nolabel="1"/>
                            </group>
                            <separator string="Cancellation Policy"/>
                            <group>
                                <field name="cancellation_policy" widget="html" nolabel="1"/>
                            </group>
                        </page>
                        <page string="Sales Integration" name="sales">
                            <group>
                                <field name="product_id"/>
                            </group>
                        </page>
                        <page string="Statistics" name="statistics">
                            <group>
                                <group>
                                    <field name="view_count"/>
                                    <field name="inquiry_count"/>
                                    <field name="booking_count"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    
    <!-- Tour Package Kanban View -->
    <record id="tour_package_view_kanban" model="ir.ui.view">
        <field name="name">tour.package.view.kanban</field>
        <field name="model">tour.package</field>
        <field name="arch" type="xml">
            <kanban sample="1">
                <field name="id"/>
                <field name="name"/>
                <field name="destination"/>
                <field name="base_price"/>
                <field name="currency_id"/>
                <field name="state"/>
                <field name="image_512"/>
                <field name="booking_count"/>
                <field name="inquiry_count"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_image">
                                <img t-att-src="kanban_image('tour.package', 'image_512', record.id.raw_value)" alt="Package"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title"><field name="name"/></strong>
                                <div class="o_kanban_record_subtitle">
                                    <i class="fa fa-map-marker"/> <field name="destination"/>
                                </div>
                                <div class="o_kanban_record_body">
                                    <field name="base_price" widget="monetary"/>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="state" widget="label_selection" options="{'classes': {'draft': 'default', 'published': 'success', 'archived': 'muted'}}"/>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <i class="fa fa-list-alt"/> <field name="booking_count"/>
                                        <i class="fa fa-question-circle"/> <field name="inquiry_count"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    
    <!-- Tour Package Search View -->
    <record id="tour_package_view_search" model="ir.ui.view">
        <field name="name">tour.package.view.search</field>
        <field name="model">tour.package</field>
        <field name="arch" type="xml">
            <search string="Search Tour Packages">
                <field name="name"/>
                <field name="code"/>
                <field name="destination"/>
                <field name="category_id"/>
                <field name="tag_ids"/>
                <filter string="Published" name="published" domain="[('state', '=', 'published')]"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Featured" name="featured" domain="[('is_featured', '=', True)]"/>
                <filter string="Popular" name="popular" domain="[('is_popular', '=', True)]"/>
                <separator/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Category" name="category" context="{'group_by': 'category_id'}"/>
                    <filter string="Destination" name="destination" context="{'group_by': 'destination'}"/>
                    <filter string="State" name="state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>
    
    <!-- Tour Package Actions -->
    <record id="action_tour_package" model="ir.actions.act_window">
        <field name="name">Tour Packages</field>
        <field name="res_model">tour.package</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{'search_default_published': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first tour package!
            </p>
            <p>
                Set up tour packages with itineraries, pricing, and all the details your customers need.
            </p>
        </field>
    </record>
    
    <!-- Tour Package Category Views -->
    <record id="tour_package_category_view_tree" model="ir.ui.view">
        <field name="name">tour.package.category.view.tree</field>
        <field name="model">tour.package.category</field>
        <field name="arch" type="xml">
            <list string="Package Categories">
                <field name="name"/>
                <field name="package_count"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    
    <record id="tour_package_category_view_form" model="ir.ui.view">
        <field name="name">tour.package.category.view.form</field>
        <field name="model">tour.package.category</field>
        <field name="arch" type="xml">
            <form string="Package Category">
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Category Name"/>
                        </h1>
                    </div>
                    <group>
                        <field name="description" placeholder="Category description..."/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    
    <record id="action_tour_package_category" model="ir.actions.act_window">
        <field name="name">Package Categories</field>
        <field name="res_model">tour.package.category</field>
        <field name="view_mode">list,form</field>
    </record>
    
    <!-- Tour Package Tag Views -->
    <record id="tour_package_tag_view_tree" model="ir.ui.view">
        <field name="name">tour.package.tag.view.tree</field>
        <field name="model">tour.package.tag</field>
        <field name="arch" type="xml">
            <list string="Package Tags" editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>
    
    <record id="action_tour_package_tag" model="ir.actions.act_window">
        <field name="name">Package Tags</field>
        <field name="res_model">tour.package.tag</field>
        <field name="view_mode">list</field>
    </record>
    
</odoo>

