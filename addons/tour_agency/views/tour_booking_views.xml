<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Tour Booking Tree View -->
    <record id="tour_booking_view_tree" model="ir.ui.view">
        <field name="name">tour.booking.view.tree</field>
        <field name="model">tour.booking</field>
        <field name="arch" type="xml">
            <list string="Tour Bookings" sample="1">
                <field name="name"/>
                <field name="booking_date"/>
                <field name="customer_name"/>
                <field name="package_name"/>
                <field name="travel_start_date"/>
                <field name="total_persons"/>
                <field name="price_total" widget="monetary"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="payment_status" decoration-success="payment_status=='paid'" decoration-warning="payment_status=='partially_paid'" decoration-danger="payment_status=='unpaid'"/>
                <field name="state" decoration-success="state=='completed'" decoration-info="state in ['confirmed','in_progress']" decoration-muted="state=='cancel'" decoration-warning="state=='draft'"/>
                <field name="user_id" widget="many2one_avatar_user"/>
            </list>
        </field>
    </record>
    
    <!-- Tour Booking Form View -->
    <record id="tour_booking_view_form" model="ir.ui.view">
        <field name="name">tour.booking.view.form</field>
        <field name="model">tour.booking</field>
        <field name="arch" type="xml">
            <form string="Tour Booking">
                <header>
                    <button name="action_confirm" type="object" string="Confirm" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_start" type="object" string="Start Tour" class="oe_highlight" invisible="state != 'confirmed'"/>
                    <button name="action_complete" type="object" string="Complete" class="oe_highlight" invisible="state != 'in_progress'"/>
                    <button name="action_register_payment" type="object" string="Register Payment" class="btn-primary" invisible="state == 'cancel' or amount_due &lt;= 0"/>
                    <button name="action_create_sale_order" type="object" string="Create Sale Order" class="btn-secondary" invisible="state == 'cancel' or sale_order_id"/>
                    <button name="action_create_invoice" type="object" string="Create Invoice" invisible="state == 'cancel' or sale_order_id or invoice_count > 0"/>
                    <button name="action_refresh_payment_status" type="object" string="Refresh Payments" class="btn-secondary" title="Refresh payment status from all linked payments and invoices"/>
                    <button name="action_cancel" type="object" string="Cancel" invisible="state in ['completed','cancel']"/>
                    <button name="action_draft" type="object" string="Set to Draft" invisible="state != 'cancel'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,in_progress,completed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_sale_order" type="object" class="oe_stat_button" icon="fa-shopping-cart" invisible="not sale_order_id">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Sale Order</span>
                            </div>
                        </button>
                        <button name="action_view_invoices" type="object" class="oe_stat_button" icon="fa-file-text-o" invisible="not invoice_count">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value"><field name="invoice_count"/></span>
                                <span class="o_stat_text">Invoices</span>
                            </div>
                        </button>
                        <button name="action_view_payments" type="object" class="oe_stat_button" icon="fa-money">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value"><field name="payment_count"/></span>
                                <span class="o_stat_text">Payments</span>
                            </div>
                        </button>
                        <button name="action_view_passengers" type="object" class="oe_stat_button" icon="fa-users" invisible="not passenger_count">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value"><field name="passenger_count"/></span>
                                <span class="o_stat_text">Passengers</span>
                            </div>
                        </button>
                        <button name="action_view_calendar_event" type="object" class="oe_stat_button" icon="fa-calendar" invisible="not calendar_event_id">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Calendar Event</span>
                            </div>
                        </button>
                        <button name="action_view_lead" type="object" class="oe_stat_button" icon="fa-star" invisible="not inquiry_id">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">CRM Lead</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Customer Information">
                            <field name="partner_id"/>
                            <field name="customer_name"/>
                            <field name="customer_email" widget="email"/>
                            <field name="customer_phone" widget="phone"/>
                        </group>
                        <group string="Booking Details">
                            <field name="package_id"/>
                            <field name="package_name" invisible="1"/>
                            <field name="booking_date"/>
                            <field name="travel_start_date"/>
                            <field name="travel_end_date"/>
                            <field name="source"/>
                        </group>
                    </group>
                    <group>
                        <group string="Passengers">
                            <field name="num_adults"/>
                            <field name="num_children"/>
                            <field name="num_infants"/>
                            <field name="total_persons"/>
                        </group>
                        <group string="Assignment">
                            <field name="user_id" widget="many2one_avatar_user"/>
                            <field name="team_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Pricing" name="pricing">
                            <group>
                                <group string="Prices">
                                    <field name="currency_id" invisible="1"/>
                                    <field name="adult_price" widget="monetary"/>
                                    <field name="child_price" widget="monetary"/>
                                    <field name="infant_price" widget="monetary"/>
                                </group>
                                <group string="Discounts &amp; Charges">
                                    <field name="discount_percentage"/>
                                    <field name="discount_amount" widget="monetary"/>
                                    <field name="extra_charges" widget="monetary"/>
                                    <field name="extra_charges_note"/>
                                </group>
                            </group>
                            <group>
                                <group>
                                    <field name="price_subtotal" widget="monetary"/>
                                    <field name="price_tax" widget="monetary"/>
                                    <field name="price_total" widget="monetary" class="oe_subtotal_footer_separator"/>
                                </group>
                                <group>
                                    <field name="payment_status" widget="badge" decoration-success="payment_status=='paid'" decoration-warning="payment_status=='partially_paid'"/>
                                    <field name="amount_paid" widget="monetary"/>
                                    <field name="amount_due" widget="monetary"/>
                                </group>
                            </group>
                        </page>
                        <page string="Passengers" name="passengers">
                            <field name="passenger_ids" context="{'default_booking_id': id}">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="passenger_type"/>
                                    <field name="gender"/>
                                    <field name="date_of_birth"/>
                                    <field name="age"/>
                                    <field name="email"/>
                                    <field name="phone"/>
                                </list>
                            </field>
                        </page>
                        <page string="Services" name="services">
                            <group>
                                <group string="Hotels">
                                    <field name="hotel_ids" widget="many2many_tags" nolabel="1"/>
                                </group>
                                <group string="Transportation">
                                    <field name="transportation_ids" widget="many2many_tags" nolabel="1"/>
                                </group>
                            </group>
                            <group>
                                <group string="Meals">
                                    <field name="meal_ids" widget="many2many_tags" nolabel="1"/>
                                </group>
                                <group string="Attractions">
                                    <field name="attraction_ids" widget="many2many_tags" nolabel="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Expenses" name="expenses">
                            <field name="expense_ids" context="{'default_booking_id': id}">
                                <list editable="bottom">
                                    <field name="date"/>
                                    <field name="name"/>
                                    <field name="expense_type"/>
                                    <field name="amount" widget="monetary" sum="total_expenses"/>
                                    <field name="currency_id" column_invisible="1"/>
                                    <field name="payment_method"/>
                                    <field name="state"/>
                                </list>
                            </field>
                            <group>
                                <group/>
                                <group>
                                    <field name="total_expenses" widget="monetary" class="oe_subtotal_footer_separator"/>
                                </group>
                            </group>
                        </page>
                        <page string="Notes &amp; Requirements" name="notes">
                            <group>
                                <field name="customer_notes" placeholder="Customer notes..."/>
                                <field name="special_requirements" placeholder="Special requirements..."/>
                                <field name="internal_notes" placeholder="Internal notes (not visible to customer)..."/>
                            </group>
                        </page>
                        <page string="Integration" name="integration">
                            <group>
                                <group string="Related Documents">
                                    <field name="inquiry_id"/>
                                    <field name="sale_order_id"/>
                                    <field name="calendar_event_id"/>
                                </group>
                                <group string="Financial">
                                    <field name="direct_invoice_ids" widget="many2many_tags"/>
                                    <field name="payment_ids" widget="many2many_tags" readonly="1"/>
                                </group>
                            </group>
                            <group string="Source &amp; Tracking">
                                <group>
                                    <field name="source"/>
                                </group>
                                <group>
                                    <label for="create_date"/>
                                    <div><field name="create_date" readonly="1"/></div>
                                    <label for="write_date"/>
                                    <div><field name="write_date" readonly="1"/></div>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    
    <!-- Tour Booking Kanban View -->
    <record id="tour_booking_view_kanban" model="ir.ui.view">
        <field name="name">tour.booking.view.kanban</field>
        <field name="model">tour.booking</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column" sample="1">
                <field name="name"/>
                <field name="customer_name"/>
                <field name="package_name"/>
                <field name="travel_start_date"/>
                <field name="price_total"/>
                <field name="payment_status"/>
                <field name="state"/>
                <field name="user_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title"><field name="name"/></strong>
                                    <div class="o_kanban_record_subtitle">
                                        <i class="fa fa-user"/> <field name="customer_name"/>
                                    </div>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <field name="package_name"/>
                                <div><i class="fa fa-calendar"/> <field name="travel_start_date"/></div>
                                <div><field name="price_total" widget="monetary"/></div>
                                <field name="payment_status" widget="badge" decoration-success="payment_status=='paid'"/>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="oe_kanban_bottom_right">
                                    <field name="user_id" widget="many2one_avatar_user"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    
    <!-- Tour Booking Calendar View -->
    <record id="tour_booking_view_calendar" model="ir.ui.view">
        <field name="name">tour.booking.view.calendar</field>
        <field name="model">tour.booking</field>
        <field name="arch" type="xml">
            <calendar string="Tour Bookings" date_start="travel_start_date" date_stop="travel_end_date" color="state" mode="month">
                <field name="name"/>
                <field name="customer_name"/>
                <field name="package_name"/>
                <field name="total_persons"/>
            </calendar>
        </field>
    </record>
    
    <!-- Tour Booking Search View -->
    <record id="tour_booking_view_search" model="ir.ui.view">
        <field name="name">tour.booking.view.search</field>
        <field name="model">tour.booking</field>
        <field name="arch" type="xml">
            <search string="Search Tour Bookings">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="package_id"/>
                <field name="user_id"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Confirmed" name="confirmed" domain="[('state', '=', 'confirmed')]"/>
                <filter string="In Progress" name="in_progress" domain="[('state', '=', 'in_progress')]"/>
                <filter string="Completed" name="completed" domain="[('state', '=', 'completed')]"/>
                <separator/>
                <filter string="Unpaid" name="unpaid" domain="[('payment_status', '=', 'unpaid')]"/>
                <filter string="Partially Paid" name="partially_paid" domain="[('payment_status', '=', 'partially_paid')]"/>
                <filter string="Paid" name="paid" domain="[('payment_status', '=', 'paid')]"/>
                <separator/>
                <filter string="My Bookings" name="my_bookings" domain="[('user_id', '=', uid)]"/>
                <separator/>
                <filter string="Booking Date" name="booking_date" date="booking_date"/>
                <filter string="Travel Date" name="travel_date" date="travel_start_date"/>
                <group expand="0" string="Group By">
                    <filter string="Customer" name="customer" context="{'group_by': 'partner_id'}"/>
                    <filter string="Package" name="package" context="{'group_by': 'package_id'}"/>
                    <filter string="State" name="state" context="{'group_by': 'state'}"/>
                    <filter string="Payment Status" name="payment" context="{'group_by': 'payment_status'}"/>
                    <filter string="Travel Month" name="travel_month" context="{'group_by': 'travel_start_date:month'}"/>
                </group>
            </search>
        </field>
    </record>
    
    <!-- Tour Booking Action -->
    <record id="action_tour_booking" model="ir.actions.act_window">
        <field name="name">Tour Bookings</field>
        <field name="res_model">tour.booking</field>
        <field name="view_mode">kanban,list,calendar,form</field>
        <field name="context">{'search_default_confirmed': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No bookings yet!
            </p>
            <p>
                Customer bookings will appear here when they book tours from your website or you create them manually.
            </p>
        </field>
    </record>
    
</odoo>

